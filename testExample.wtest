import bebidas.*
import tito.*

describe "tito el bambino" {
  test "tito consume 10 whiskys y su sustancia es whisky" {
    tito.consumir(10, whisky)
    assert.equals(whisky, tito.sustanciaActual())
  }
}

test "tito consume 10 whiskys y su dosis es 10" {
    tito.consumir(10, whisky)
    assert.equals(10, tito.dosisConsumida())
  }

